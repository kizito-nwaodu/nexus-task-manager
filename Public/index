<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Nexus | Modern PM</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <style>
        .glass { background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); }
        body { background: #020617; color: white; font-family: 'Inter', sans-serif; }
    </style>
</head>
<body>
    <!-- Auth Screen -->
    <div id="auth-screen" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950">
        <div class="glass p-10 rounded-3xl w-full max-w-md">
            <h1 class="text-3xl font-bold mb-6 text-center">Nexus Login</h1>
            <input id="login-email" type="email" placeholder="Email" class="w-full p-3 rounded-lg bg-white/5 border border-white/10 mb-4">
            <input id="login-pass" type="password" placeholder="Password" class="w-full p-3 rounded-lg bg-white/5 border border-white/10 mb-6">
            <button onclick="login()" class="w-full py-3 bg-indigo-600 rounded-lg font-bold">Sign In</button>
            <p class="mt-4 text-center text-gray-500 text-sm">Demo: admin@nexus.com / password</p>
        </div>
    </div>

    <!-- Main App -->
    <div id="app" class="hidden">
        <nav class="glass p-4 sticky top-0 z-40">
            <div class="max-w-7xl mx-auto flex justify-between items-center">
                <div class="flex items-center space-x-3">
                    <div class="bg-indigo-600 p-2 rounded-lg"><i data-lucide="layers"></i></div>
                    <span class="text-xl font-bold">Nexus</span>
                </div>
                <div class="flex space-x-6">
                    <button onclick="setView('dashboard')">Board</button>
                    <button onclick="setView('projects')">Projects</button>
                    <button onclick="exportCSV()" class="bg-indigo-600/20 text-indigo-400 px-3 py-1 rounded-lg border border-indigo-500/30">Export Report</button>
                    <button onclick="logout()" class="text-red-400">Logout</button>
                </div>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto p-6">
            <div id="view-dashboard">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="kanban">
                    <!-- Column: To Do -->
                    <div class="space-y-4">
                        <h3 class="text-gray-400 font-bold uppercase text-xs tracking-widest">To Do</h3>
                        <div id="col-todo" class="min-h-[400px] bg-white/5 rounded-xl p-4"></div>
                    </div>
                    <!-- Column: In Progress -->
                    <div class="space-y-4">
                        <h3 class="text-indigo-400 font-bold uppercase text-xs tracking-widest">In Progress</h3>
                        <div id="col-progress" class="min-h-[400px] bg-white/5 rounded-xl p-4"></div>
                    </div>
                    <!-- Column: Done -->
                    <div class="space-y-4">
                        <h3 class="text-emerald-400 font-bold uppercase text-xs tracking-widest">Completed</h3>
                        <div id="col-done" class="min-h-[400px] bg-white/5 rounded-xl p-4"></div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        const API = "http://localhost:3000/api";
        let userToken = localStorage.getItem('token');

        // Logic
        async function login() {
            const email = document.getElementById('login-email').value;
            const password = document.getElementById('login-pass').value;
            try {
                const res = await axios.post(`${API}/login`, { email, password });
                localStorage.setItem('token', res.data.token);
                location.reload();
            } catch (e) { alert("Login failed"); }
        }

        function logout() {
            localStorage.clear();
            location.reload();
        }

        async function loadTasks() {
            const res = await axios.get(`${API}/tasks`, { headers: { Authorization: userToken }});
            const tasks = res.data;
            ['todo', 'progress', 'done'].forEach(status => {
                const col = document.getElementById(`col-${status}`);
                col.innerHTML = '';
                tasks.filter(t => t.status === status).forEach(task => {
                    col.innerHTML += `
                        <div class="glass p-4 rounded-xl mb-3 shadow-lg border-l-4 border-indigo-500">
                            <h4 class="font-bold mb-1">${task.title}</h4>
                            <p class="text-xs text-gray-400">${task.desc}</p>
                        </div>
                    `;
                });
            });
            lucide.createIcons();
        }

        function exportCSV() {
            window.open(`${API}/export-tasks?token=${userToken}`);
            // Logic to generate CSV in real time
            alert("Exporting project data to CSV...");
        }

        if (userToken) {
            document.getElementById('auth-screen').classList.add('hidden');
            document.getElementById('app').classList.remove('hidden');
            loadTasks();
        }
    </script>
</body>
</html>
