<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Nexus | Manage Everything</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>
<body class="bg-[#020617] text-slate-200 font-sans">

    <!-- Login -->
    <div id="auth-ui" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950">
        <div class="bg-slate-900 p-8 rounded-2xl border border-white/10 w-80 text-center">
            <h2 class="text-2xl font-bold mb-6">Nexus Login</h2>
            <input id="email" type="email" placeholder="Email" class="w-full mb-3 p-3 bg-white/5 rounded-lg">
            <input id="pass" type="password" placeholder="Password" class="w-full mb-6 p-3 bg-white/5 rounded-lg">
            <button onclick="login()" class="w-full bg-indigo-600 py-3 rounded-lg font-bold">Launch App</button>
        </div>
    </div>

    <!-- Main Workspace -->
    <div id="app" class="hidden min-h-screen">
        <nav class="p-4 bg-slate-900/50 border-b border-white/5 backdrop-blur-md sticky top-0">
            <div class="max-w-7xl mx-auto flex justify-between items-center">
                <div class="flex items-center space-x-2 text-indigo-400 font-bold text-xl">
                    <i data-lucide="layers"></i><span>Nexus</span>
                </div>
                <div class="flex items-center space-x-4">
                    <button onclick="exportCSV()" class="bg-indigo-500/10 text-indigo-400 px-4 py-2 rounded-lg text-sm border border-indigo-500/20">Export CSV</button>
                    <button onclick="logout()" class="text-slate-500 text-sm">Logout</button>
                </div>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto p-8">
            <div class="flex justify-between items-end mb-8">
                <div>
                    <h1 class="text-4xl font-bold mb-2">Workspace</h1>
                    <p class="text-slate-500">Manage your project milestones</p>
                </div>
                <button onclick="addTask()" class="bg-indigo-600 px-6 py-3 rounded-xl font-bold flex items-center space-x-2">
                    <i data-lucide="plus" class="w-5 h-5"></i><span>New Task</span>
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="bg-slate-900/40 p-6 rounded-2xl min-h-[500px]" ondragover="allowDrop(event)" ondrop="drop(event, 'todo')">
                    <h3 class="text-slate-500 font-bold mb-6 uppercase text-xs tracking-widest">Backlog</h3>
                    <div id="todo-list" class="space-y-4"></div>
                </div>
                <div class="bg-slate-900/40 p-6 rounded-2xl min-h-[500px]" ondragover="allowDrop(event)" ondrop="drop(event, 'progress')">
                    <h3 class="text-indigo-400 font-bold mb-6 uppercase text-xs tracking-widest">In Progress</h3>
                    <div id="progress-list" class="space-y-4"></div>
                </div>
                <div class="bg-slate-900/40 p-6 rounded-2xl min-h-[500px]" ondragover="allowDrop(event)" ondrop="drop(event, 'done')">
                    <h3 class="text-emerald-400 font-bold mb-6 uppercase text-xs tracking-widest">Completed</h3>
                    <div id="done-list" class="space-y-4"></div>
                </div>
            </div>
        </main>
    </div>

    <script>
        let tasks = [];
        const token = localStorage.getItem('nexus_token');

        async function login() {
            const email = document.getElementById('email').value;
            const password = document.getElementById('pass').value;
            const res = await axios.post('/api/login', { email, password });
            localStorage.setItem('nexus_token', res.data.token);
            location.reload();
        }

        function logout() { localStorage.clear(); location.reload(); }

        async function loadTasks() {
            const res = await axios.get('/api/tasks', { headers: { Authorization: token } });
            tasks = res.data;
            render();
        }

        function render() {
            ['todo', 'progress', 'done'].forEach(status => {
                const list = document.getElementById(`${status}-list`);
                list.innerHTML = '';
                tasks.filter(t => t.status === status).forEach(task => {
                    list.innerHTML += `
                        <div draggable="true" ondragstart="drag(event, ${task.id})" class="bg-slate-800 p-5 rounded-xl border border-white/5 cursor-move hover:border-indigo-500/50 transition-all">
                            <div class="text-[10px] font-bold text-indigo-400 mb-2 uppercase tracking-widest">${task.priority}</div>
                            <h4 class="font-bold mb-1">${task.title}</h4>
                            <p class="text-xs text-slate-500">${task.desc}</p>
                        </div>
                    `;
                });
            });
            lucide.createIcons();
        }

        function drag(e, id) { e.dataTransfer.setData("text", id); }
        function allowDrop(e) { e.preventDefault(); }
        async function drop(e, status) {
            const id = e.dataTransfer.getData("text");
            await axios.put(`/api/tasks/${id}`, { status }, { headers: { Authorization: token } });
            loadTasks();
        }

        async function addTask() {
            const title = prompt("Task Name:");
            if (!title) return;
            await axios.post('/api/tasks', { title, desc: 'Project Details...', status: 'todo', priority: 'medium' }, { headers: { Authorization: token } });
            loadTasks();
        }

        function exportCSV() {
            let csv = "ID,Title,Status,Priority\n";
            tasks.forEach(t => csv += `${t.id},${t.title},${t.status},${t.priority}\n`);
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = "nexus-report.csv";
            a.click();
        }

        if (token) {
            document.getElementById('auth-ui').classList.add('hidden');
            document.getElementById('app').classList.remove('hidden');
            loadTasks();
        }
    </script>
</body>
</html>
